---
// src/pages/projects.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects | komotiii HQ" description="Detailed page for all projects, tools, and technical stack.">
    <main>
        <section class="content-section reveal layer-professional">
            <div class="section-head">
                <p class="kicker">01 / Data Engineering</p>
                <h2>Data Collection & Analysis</h2>
            </div>
            <div class="card-grid card-grid-two">
                <article class="project-card">
                    <h3>Pachi-Slot Analyzer</h3>
                    <p class="summary">High-speed, parallel Selenium scraper that automatically discovers hierarchical machine URLs. Features robust retry mechanisms and structured CSV exports for immediate data analysis.</p>
                    <ul class="tech-tags"><li>Python</li><li>Selenium</li><li>Parallel Processing</li></ul>
                    <a class="card-link" href="https://github.com/komotiii/pachi-slot-analyzer" target="_blank" rel="noopener noreferrer">View on GitHub</a>
                </article>
                <article class="project-card">
                    <h3>NAR Keiba Monitor</h3>
                    <p class="summary">Real-time web scraper for local horse racing odds. Continuously monitors metrics, highlights profitable win-rate/odds combinations, and triggers local audio alerts before deadlines.</p>
                    <ul class="tech-tags"><li>Python</li><li>Real-time Data</li><li>Scraping</li></ul>
                    <a class="card-link" href="https://github.com/komotiii/nar-keiba-monitor" target="_blank" rel="noopener noreferrer">View on GitHub</a>
                </article>
            </div>
        </section>

        <section class="content-section reveal layer-professional">
            <div class="section-head">
                <p class="kicker">02 / FinTech</p>
                <h2>Trading Systems & Crypto</h2>
            </div>
            <div class="card-grid card-grid-two">
                <article class="project-card">
                    <h3>Bybit Trading Tools</h3>
                    <p class="summary">Suite of algorithmic trading scripts. Automates USDC/USDT arbitrage, BUSD cyclical price divergence capturing, and P2P transaction profit calculations via Bybit APIs.</p>
                    <ul class="tech-tags"><li>Python</li><li>Algorithmic Trading</li><li>API</li></ul>
                    <a class="card-link" href="https://github.com/komotiii/Bybit-Trading-Tools" target="_blank" rel="noopener noreferrer">View on GitHub</a>
                </article>

                <article class="project-card private-zone">
                    <h3>Bybit Trading Panel</h3>
                    <p class="summary">[Private Repository] Professional-grade dual-account hedging system for perpetual futures. Features a FastAPI backend, React UI, and an event-driven WebSocket monitor with a 6-stage dynamic grid strategy.</p>
                    <ul class="tech-tags"><li>FastAPI</li><li>React</li><li>WebSockets</li></ul>
                    <span class="card-link card-link-muted">Code is Private</span>
                </article>
            </div>
        </section>

        <section class="content-section reveal layer-professional">
            <div class="section-head">
                <p class="kicker">03 / Utility</p>
                <h2>Automation & OS Config</h2>
            </div>
            <div class="card-grid card-grid-two">
                <article class="project-card">
                    <h3>Python Automation Scripts</h3>
                    <p class="summary">Comprehensive suite automating daily workflows. Integrates Google Calendar and OpenWeather APIs, performs extensive desktop usage monitoring, and powers custom Discord notification bots.</p>
                    <ul class="tech-tags"><li>Python</li><li>API Integration</li><li>Workflow Ops</li></ul>
                    <a class="card-link" href="https://github.com/komotiii/python-automation-scripts" target="_blank" rel="noopener noreferrer">View on GitHub</a>
                </article>
                <article class="project-card">
                    <h3>Windows Workspace Config</h3>
                    <p class="summary">Advanced AutoHotkey automation for OS-level efficiency. Orchestrates complex multi-window startup sequences, custom keybinds, and dynamic layout configurations.</p>
                    <ul class="tech-tags"><li>AutoHotkey</li><li>OS Automation</li><li>Productivity</li></ul>
                    <a class="card-link" href="https://github.com/komotiii/windows-workspace-config" target="_blank" rel="noopener noreferrer">View on GitHub</a>
                </article>
                <article class="project-card">
                    <h3>SAO Calendar UI</h3>
                    <p class="summary">Immersive, Sword Art Online-themed schedule dashboard. Combines a Python API backend for Google Calendar data with a custom JS/CSS frontend featuring real-time countdowns and audio cues.</p>
                    <ul class="tech-tags"><li>Full-Stack</li><li>UI/UX</li><li>Google APIs</li></ul>
                    <a class="card-link" href="https://github.com/komotiii/sao-calendar-ui" target="_blank" rel="noopener noreferrer">View on GitHub</a>
                </article>
            </div>
        </section>

        <section class="content-section reveal layer-professional">
            <div class="section-head">
                <p class="kicker">04 / Hardware & Core</p>
                <h2>AI, IoT & Algorithms</h2>
            </div>
            <div class="card-grid card-grid-two">
                <article class="project-card">
                    <h3>Posture Monitor (MediaPipe)</h3>
                    <p class="summary">Real-time computer vision application using OpenCV and MediaPipe. Tracks facial and shoulder landmarks to detect slouching, triggering audible alerts to correct user posture.</p>
                    <ul class="tech-tags"><li>Computer Vision</li><li>MediaPipe</li><li>OpenCV</li></ul>
                    <a class="card-link" href="https://github.com/komotiii/posture-monitor" target="_blank" rel="noopener noreferrer">View on GitHub</a>
                </article>
                <article class="project-card">
                    <h3>Raspi Env Monitor</h3>
                    <p class="summary">Raspberry Pi-based smart home integration. Analyzes infrared signals for AC control and correlates room temperature/humidity data, serving insights via a local Flask dashboard.</p>
                    <ul class="tech-tags"><li>Raspberry Pi</li><li>IoT</li><li>Signal Analysis</li></ul>
                    <a class="card-link" href="https://github.com/komotiii/raspi-home-iot" target="_blank" rel="noopener noreferrer">View on GitHub</a>
                </article>
                <article class="project-card">
                    <h3>C++ Math Utils</h3>
                    <p class="summary">High-performance command-line toolset. Includes statistical dataset analyzers, robust countdown/progress trackers, and multiple prime number generation algorithms optimized up to trial division by square root.</p>
                    <ul class="tech-tags"><li>C++</li><li>Algorithms</li><li>CLI</li></ul>
                    <a class="card-link" href="https://github.com/komotiii/cpp-math-utils" target="_blank" rel="noopener noreferrer">View on GitHub</a>
                </article>
            </div>
        </section>

        <section class="content-section reveal layer-professional">
            <div class="section-head">
                <p class="kicker">Capabilities</p>
                <h2>Skills and Stack</h2>
            </div>
            <div class="skills-grid">
                <article class="skill-card"><h3>Language & Framework</h3><ul class="tech-tags"><li>Python</li><li>FastAPI</li><li>React</li><li>JavaScript</li><li>SQL</li><li>C++</li><li>Bash</li></ul></article>
                <article class="skill-card"><h3>Data & Infrastructure</h3><ul class="tech-tags"><li>Pandas</li><li>NumPy</li><li>Selenium</li><li>API Design</li><li>ETL</li><li>Monitoring</li><li>Git</li></ul></article>
                <article class="skill-card"><h3>Scientific Tools</h3><ul class="tech-tags"><li>ROOT</li><li>HEP Analysis</li><li>Mathematica</li><li>Jupyter</li><li>Linux</li><li>LaTeX</li></ul></article>
                <article class="skill-card"><h3>Development Ops</h3><ul class="tech-tags"><li>Docker</li><li>GitHub Actions</li><li>Automation</li><li>VSCode</li><li>Obsidian</li><li>AutoHotkey</li></ul></article>
            </div>
        </section>

    </main>
    </BaseLayout>
