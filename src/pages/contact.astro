---
// src/pages/projects.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects | komotiii HQ" description="Detailed page for all projects, tools, and technical stack.">
        <main>
        <section class="content-section reveal layer-personal">
            <div class="section-head"><p class="kicker">Contact</p><h2>Primary Links</h2></div>
            <div class="card-grid card-grid-two">
                <article class="project-card">
                    <h3>Primary Links</h3>
                    <ul class="bullet-list">
                        <li><a href="https://github.com/komotiii" target="_blank" rel="noopener noreferrer">GitHub</a></li>
                        <li><a href="https://komotiii.github.io/" target="_blank" rel="noopener noreferrer">Homepage</a></li>
                        <li><a href="schedule/index.html" target="_blank" rel="noopener noreferrer">Schedule</a></li>
                    </ul>
                </article>
                <article class="project-card">
                    <h3>SNS</h3>
                    <ul class="bullet-list">
                        <li><a href="#" aria-label="X account link">X（Yet）</a></li>
                        <li><a href="#" aria-label="Instagram account link">Instagram（Yet）</a></li>
                        <li><a href="#" aria-label="LinkedIn account link">LinkedIn（Yet）</a></li>
                    </ul>
                </article>
            </div>
        </section>
    </main>
    </BaseLayout>

