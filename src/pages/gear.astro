---
// src/pages/projects.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects | komotiii HQ" description="Detailed page for all projects, tools, and technical stack.">
    <main>
        <section class="content-section reveal layer-personal">
            <div class="section-head"><p class="kicker">Workspace and Gear</p><h2>💻 Development Environment and Gear</h2></div>
            <div class="card-grid card-grid-two">
                <article class="project-card hardware-list"><h3>Desktop PC</h3><ul><li><strong>Build Date:</strong> 2018/10/09</li><li><strong>OS:</strong> Windows 11 Pro</li><li><strong>Motherboard:</strong> MSI H370 GAMING PLUS</li><li><strong>CPU:</strong> Intel Core i5-9400F</li><li><strong>RAM:</strong> 48GB</li><li><strong>GPU:</strong> NVIDIA GeForce GTX 1060 6GB</li><li><strong>Storage:</strong> 2TB NVMe SSD / 480GB SATA SSD / 1TB HDD</li></ul></article>
                <article class="project-card hardware-list"><h3>Laptop PC</h3><ul><li><strong>Operation Start:</strong> 2022/03/24</li><li><strong>Model:</strong> HP (BaseBoard: 887A)</li><li><strong>OS:</strong> Windows 11 Home</li><li><strong>CPU:</strong> AMD Ryzen 5 5500U with Radeon Graphics</li><li><strong>RAM:</strong> 16GB</li><li><strong>GPU:</strong> AMD Radeon Graphics (Integrated)</li><li><strong>Storage:</strong> 512GB NVMe SSD (SK hynix BC711)</li></ul></article>
                <article class="project-card hardware-list"><h3>Peripherals</h3><ul><li><strong>Keyboard:</strong> FILCO Majestouch 2SS Edition</li><li><strong>Switches:</strong> Cherry MX Speed Silver</li><li><strong>Layout:</strong> Tenkeyless / Japanese layout (91 keys)</li><li><strong>Keycaps:</strong> PBT double-shot, two-tone</li><li><strong>Features:</strong> N-key rollover / function key support</li><li><strong>Mouse:</strong> Logicool G PRO Wireless (G-PPD-003WL-WH)</li><li><strong>Desk:</strong> Flexispot EG8-EW8WMJA</li></ul></article>
                <article class="project-card hardware-list"><h3>Software and Preferences</h3><ul><li><strong>Environment Sync:</strong> Synchronized terminal environment</li><li><strong>Key Remap:</strong> Caps Lock to Backspace / Henkan to Kana key / Muhenkan to A</li><li><strong>Knowledge Management:</strong> Obsidian</li><li><strong>Editor and Terminal:</strong> VSCode</li></ul></article>
            </div>
        </section>
    </main>
    </BaseLayout>
