---
// src/layouts/BaseLayout.astro
import Header from '../components/Header.astro';

// 各ページから受け取る変数（タイトルと説明文）
const { title, description } = Astro.props;
const siteName = 'komotiii HQ';
const resolvedTitle = title ?? `${siteName} | Home`;
const resolvedDescription = description ?? 'Engineering portfolio, current status, and personal logs by komotiii.';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const currentYear = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={resolvedDescription}>
    <meta name="theme-color" content="#09090b">
    <meta name="color-scheme" content="dark">
    <link rel="canonical" href={canonicalUrl.href}>

    <meta property="og:site_name" content={siteName}>
    <meta property="og:title" content={resolvedTitle}>
    <meta property="og:description" content={resolvedDescription}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalUrl.href}>

    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content={resolvedTitle}>
    <meta name="twitter:description" content={resolvedDescription}>

    <title>{resolvedTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="/main.css">
</head>
<body>
    <a class="skip-link" href="#top">Skip to content</a>

    <Header />

    <slot />

    <footer>
        <p>© {currentYear} komotiii</p>
    </footer>
</body>
</html>
